{
  "name": "esday-demo-angular",
  "version": "0.6.4-Angular21",
  "description": "Minimal demo for using the esday library in a basic Angular app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BePo65/esday-demo-angular.git"
  },
  "keywords": [
    "esday",
    "demo",
    "angular",
    "date",
    "time",
    "immutable",
    "moment",
    "dayjs",
    "format"
  ],
  "author": "BePo65",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/BePo65/esday-demo-angular/issues"
  },
  "homepage": "https://github.com/BePo65/esday-demo-angular#readme",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:watch": "ng build --watch --configuration development",
    "build:ghpages": "npm run build:prod -- --base-href=/esday-demo-angular/ && del-cli ghpages && cpy \"dist/esday-demo-angular/browser/**\" ghpages  && cpy \"dist/esday-demo-angular/3rdpartylicenses.txt\" ghpages --flat && cpy README.md ghpages && cpy LICENSE ghpages",
    "test": "ng test",
    "test:run": "ng test --watch=false",
    "test:coverage": "ng test --coverage --watch=false",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "lint": "ng lint"
  },
  "private": false,
  "dependencies": {
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/router": "^22.0.6",
    "esday": "^1.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "cpy-cli": "^7.0.0",
    "del-cli": "^7.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "msgpackr-extract@3.0.4": true,
    "lmdb@3.5.4": true,
    "esbuild@0.28.1": true
  }
}
